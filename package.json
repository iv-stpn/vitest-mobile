{
  "name": "rn-test-runner",
  "private": true,
  "type": "module",
  "workspaces": [
    "packages/*",
    "test-packages/*"
  ],
  "scripts": {
    "lint": "eslint .",
    "check-types": "tsc --noEmit --project packages/vitest-mobile/tsconfig.json",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "lint:all": "bun run lint && bun run check-types && bun run format:check",
    "build": "bun run --filter vitest-mobile build",
    "dev": "bun run --filter vitest-mobile dev",
    "test": "vitest run --project ios",
    "test:ios": "bun run build && vitest run --project ios",
    "test:android": "bun run build && vitest run --project android",
    "test:dev": "bun run build && vitest --project ios",
    "test:dev:android": "bun run build && vitest --project android",
    "release": "bun run build && bunx changeset publish"
  },
  "overrides": {
    "react": "19.2.7",
    "react-native": "0.86.0"
  },
  "devDependencies": {
    "@changesets/cli": "^2.30.0",
    "@eslint/js": "^9.39.4",
    "@types/connect": "^3.4.38",
    "eslint": "^9.39.4",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.4.0",
    "prettier": "^3.8.1",
    "typescript-eslint": "^8.58.0",
    "vite": "^8",
    "vitest": "^4",
    "vitest-mobile": "workspace:*"
  },
  "version": "1.0.0",
  "dependencies": {
    "react": "19.2.7",
    "react-native": "0.86.0",
    "react-native-safe-area-context": "^5.7.0"
  },
  "packageManager": "bun@1.3.12"
}
